# Mirage — Environment Variables
# Copy this file to .env and update values for your environment

# ── Security ──────────────────────────────────────────────────────────────────
# REQUIRED — generate a strong random value, never reuse across environments
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_DB=mirage_db
POSTGRES_USER=your_db_user
POSTGRES_PASSWORD=your_db_password
DATABASE_URL=postgresql+asyncpg://your_db_user:your_db_password@localhost:5432/mirage_db

# ── Application ───────────────────────────────────────────────────────────────
DEBUG=false
ENVIRONMENT=production

# ── CORS ──────────────────────────────────────────────────────────────────────
# Add your frontend domains here
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:80"]

# ── ML Engine ─────────────────────────────────────────────────────────────────
# How often the simulator generates transactions (seconds)
SIMULATOR_INTERVAL_SECONDS=3.0

# Risk thresholds
ANOMALY_THRESHOLD=0.75

# ── Frontend ──────────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8000
