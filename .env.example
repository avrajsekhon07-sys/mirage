# Mirage — Environment Variables
# Copy this file to .env and update values for your environment

# ── Security ──────────────────────────────────────────────────────────────────
# IMPORTANT: Change this to a strong random secret in production!
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=mirage-super-secret-key-change-this-in-production-abc123xyz

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_DB=mirage_db
POSTGRES_USER=mirage
POSTGRES_PASSWORD=mirage_pass
DATABASE_URL=postgresql+asyncpg://mirage:mirage_pass@db:5432/mirage_db

# ── Application ───────────────────────────────────────────────────────────────
DEBUG=false
ENVIRONMENT=production

# ── CORS ──────────────────────────────────────────────────────────────────────
# Add your frontend domains here
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:80"]

# ── ML Engine ─────────────────────────────────────────────────────────────────
# How often the simulator generates transactions (seconds)
SIMULATOR_INTERVAL_SECONDS=3.0

# Risk thresholds
ANOMALY_THRESHOLD=0.75

# ── Frontend ──────────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8000
